# Include machine-specific config (not tracked in git)
config-file = ~/.config/ghostty/local.config

font-family = "MesloLGM Nerd Font Mono"
# font-size is set in local.config (machine-specific)
#font-feature = -liga
font-thicken = true
font-style = Regular
theme = catppuccin-mocha
quit-after-last-window-closed = true

# Enable mouse reporting for tmux
mouse-hide-while-typing = false
click-repeat-interval = 0
keybind = shift+enter=text:\x1b\r
